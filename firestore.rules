rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 기본 정책: 모든 작업 차단
    match /{document=**} {
      allow read, write: if false;
    }

    // posts 컬렉션: 공개 읽기만 허용, 쓰기는 모두 차단
    // 외부 자동 발행을 차단하기 위해 모든 쓰기 권한 제거
    // (사이트는 src/constants.ts의 정적 데이터를 사용)
    match /posts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
