rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 &&
             data.content is string && data.content.size() > 0 &&
             data.category is string &&
             data.author is string &&
             data.date is string;
    }

    match /posts/{postId} {
      // Allow public read for all posts
      allow get, list: if true;
      
      // Allow authenticated users to create posts for this demo
      allow create: if isSignedIn() && isValidPost(request.resource.data);
      allow update, delete: if false; 
    }
  }
}
